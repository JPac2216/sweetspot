<div class="auth-page">
    <img src="/css/Sweet%20Spot.png" alt="Sweet Spot" class="logo-hero">

    <form class="auth-box" action="/login" method="POST">
        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="your@email.com" required>
        </div>

        <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" placeholder="••••••••" required>
        </div>

        <div class="btn-row">
            <button type="submit" class="btn btn-filled">Login</button>
            <span class="hint">New user?</span>
            <a href="/register" class="btn">Create Account</a>
        </div>
    </form>
</div>
