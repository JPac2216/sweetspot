{{> navbar}}

<div class="page">
    <div class="card">
        <h1>{{spot.name}}</h1>
        <div class="date-meta">{{spot.address.borough}} / {{spot.address.street}}{{#if spot.address.zip}}, {{spot.address.zip}}{{/if}}</div>
        {{#if spot.sweetspotRating.average}}
        <div class="date-meta">Rating: {{spot.sweetspotRating.average}} ({{spot.sweetspotRating.count}} reviews)</div>
        {{else}}
        <div class="date-meta">No ratings yet</div>
        {{/if}}
        <div class="filter-group">
            <button type="button" class="btn btn-blue filter-toggle" onclick="toggleFilter(this)">Add to Date</button>
            <div class="filter-dropdown">
                {{#each userDates}}
                <form id="add-spot-form-{{this._id}}" action="/date/{{this._id}}/addSpot" method="POST">
                    <input type="hidden" name="dateSpotId" value="{{../spot._id}}">
                    <button type="submit" class="btn">{{this.title}}</button>
                </form>
                {{else}}
                <span>No dates created yet.</span>
                {{/each}}
            </div>
            {{#if isAdmin}}
                <a href="/admin/spots/{{spot._id}}/edit" class="btn btn-blue">Edit Spot</a>
            {{/if}}
        </div>
    </div>

    <div class="card">
        <p>{{spot.description}}</p>
        {{#if spot.tags.length}}
        <div class="tags">
            {{#each spot.tags}}
            <span class="tag">{{this}}</span>
            {{/each}}
        </div>
        {{/if}}
    </div>

    <div class="reviews-section">
        <div class="section-header">
            <h2 class="section-title">Reviews and Comments</h2>
            <a href="/spots/{{spot._id}}/review" class="btn btn-blue">Add Review</a>
        </div>
        {{#each spot.reviews}}
        <div class="appeal-card">
            <div>
                <span>@{{this.username}}</span>
                <span class="date-meta">Rating: {{this.rating}}</span>
            </div>
            <p>{{this.comment}}</p>
            <div class="date-meta">{{this.createdAt}}</div>
            {{#if this.canDelete}}
            <form action="/spots/{{../spot._id}}/review/{{this._id}}/delete" method="POST" class="form-inline">
                <button type="submit" class="btn btn-red">Delete</button>
            </form>
            {{/if}}
        </div>
        {{else}}
        <p>No reviews yet.</p>
        {{/each}}

        {{#if isLoggedIn}}
        {{#unless hasReviewed}}
        <form action="/spots/{{spot._id}}/review" method="POST" class="review-form">
            <h3>Leave a Review</h3>
            <div class="form-group">
                <label>Rating</label>
                <select name="rating" required>
                    <option value="">Select...</option>
                    <option value="1">1 star</option>
                    <option value="2">2 stars</option>
                    <option value="3">3 stars</option>
                    <option value="4">4 stars</option>
                    <option value="5">5 stars</option>
                </select>
            </div>
            <div class="form-group">
                <label>Review</label>
                <textarea name="review" placeholder="Share your experience..." maxlength="500" required></textarea>
            </div>
            <button type="submit" class="btn btn-blue">Post Review</button>
        </form>
        {{/unless}}
        {{else}}
        <p><a href="/signin">Log in</a> to leave a review.</p>
        {{/if}}
    </div>
</div>

{{> filterDropdown}}
