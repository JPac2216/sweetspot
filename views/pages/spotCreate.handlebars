{{> navbar}}

<div class="page">
    <div class="form-page">
        <h1 class="page-title">Create a Spot</h1>

        {{#if error}}
        <p class="error">{{error}}</p>
        {{/if}}

        <form id="spot-create-form" class="form-box" action="/spots/create" method="POST">
            <div class="form-group">
                <label for="name">Spot Name</label>
                <input type="text" id="name" name="name" class="name" placeholder="e.g. Prospect Park" required>
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" class="description" placeholder="Describe the spot..." required></textarea>
            </div>

            <div class="form-group">
                <label for="street">Street Address</label>
                <input type="text" id="street" name="street" class="street" placeholder="e.g. 1 Main St" required>
            </div>

            <div class="form-group">
                <label for="borough">Borough</label>
                <select id="borough" name="borough" class="borough" required>
                    <option value="manhattan">Manhattan</option>
                    <option value="brooklyn">Brooklyn</option>
                    <option value="queens">Queens</option>
                    <option value="the bronx">The Bronx</option>
                    <option value="staten island">Staten Island</option>
                </select>
            </div>

            <div class="form-group">
                <label for="zip">Zip Code</label>
                <input type="text" id="zip" name="zip" class="zip" placeholder="e.g. 10001" required>
            </div>

            <div class="form-group">
                <label for="tags">Tags (optional, comma-separated)</label>
                <input type="text" id="tags" name="tags" class="tags" placeholder="e.g. food, outdoor, romantic">
            </div>

            <div class="form-actions">
                <button id="spot-submit-btn" type="submit" class="btn btn-blue">Create Spot</button>
            </div>

            <p>Admins create the spot directly. Members submit an appeal for review.</p>
        </form>
    </div>
</div>

{{> spotCreate}}
