<nav class="navbar">
    <a href="/user/home"><img src="/css/Sweet%20Spot.png" alt="Sweet Spot" class="logo"></a>
    <div class="nav-links">
        <a href="/explore" class="nav-btn">Explore</a>
        <a href="/appeal" class="nav-btn">Appeal</a>
        <a href="/date/create" class="nav-btn nav-btn-blue">Create +</a>
        <a href="/user/profile"><img src="/css/profile_icon.png" alt="My Profile" class="nav-icon"></a>
    </div>
</nav>

<div class="auth-page">
    <form class="auth-box" action="/signin" method="POST">
        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="your@email.com" required>
        </div>

        <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" placeholder="••••••••" required>
        </div>
    </form>
</div>

<div class="page">
    <div class="form-page">
        <h1 class="page-title">Edit Profile</h1>

        {{#if error}}
        <p class="error">{{error}}</p>
        {{/if}}

        <form class="form-box" action="/user/profile/edit" method="POST">
            <div class="form-group">
                <label for="firstName">First Name</label>
                <input type="text" id="firstName" name="firstName" value="{{member.firstName}}">
            </div>

            <div class="form-group">
                <label for="lastName">Last Name</label>
                <input type="text" id="lastName" name="lastName" value="{{member.lastName}}">
            </div>

            <div class="form-group">
                <label for="username">Username</label>
                <input type="text" id="username" name="username" value="{{member.username}}">
            </div>

            <div class="form-group">
                <label for="editEmail">Email</label>
                <input type="email" id="editEmail" name="email" value="{{member.email}}">
            </div>

            <div class="form-group">
                <label for="gender">Gender</label>
                <input type="text" id="gender" name="gender" value="{{member.gender}}">
            </div>

            <div class="form-group">
                <label for="primaryLocation">Primary Location</label>
                <input type="text" id="primaryLocation" name="primaryLocation" value="{{member.primaryLocation}}">
            </div>

            <div class="form-group">
                <label for="secondaryLocation">Secondary Location (optional)</label>
                <input type="text" id="secondaryLocation" name="secondaryLocation" value="{{member.secondaryLocation}}">
            </div>

            <div class="form-group">
                <label for="currentPassword">Current Password</label>
                <input type="password" id="currentPassword" name="currentPassword" required>
            </div>

            <div class="form-group">
                <label for="newPassword">New Password (leave blank to keep current)</label>
                <input type="password" id="newPassword" name="newPassword">
            </div>

            <div class="btn-row">
                <button type="submit" class="btn btn-filled">Save Changes</button>
                <a href="/user/profile" class="btn">Cancel</a>
            </div>
        </form>
    </div>
</div>
