{{> navbar}}

<div class="page">
    <div>
        <div class="page-header">
            <h1 class="page-title">{{date.title}}</h1>
            {{#if date.isCreator}}
            <form action="/date/{{date._id}}/delete" method="POST" class="form-inline" onsubmit="return confirm('Delete this date? This cannot be undone.');">
                <button type="submit" class="btn btn-red">Delete</button>
            </form>
            {{else}}{{#if isAdmin}}
            <form action="/admin/dates/{{date._id}}/delete" method="POST" class="form-inline" onsubmit="return confirm('Delete this date? This cannot be undone.');">
                <button type="submit" class="btn btn-red">Delete (Admin)</button>
            </form>
            {{/if}}{{/if}}
        </div>
        <div class="tags">
            {{#each date.tags}}
            <span class="tag">{{this}}</span>
            {{/each}}
        </div>
        <div class="date-meta">
            {{date.borough}} / est. ${{date.estimatedCost}} / by
            <a href="/date/creator/{{date.createdById}}">@{{date.createdByUsername}}</a>
        </div>
        <div class="date-meta">{{date.createdAt}}</div>

        {{#if date.isCreator}}
        <div class="creator-controls">
            {{#if date.isPublic}}
            <form action="/date/{{date._id}}/private" method="POST" class="form-inline">
                <button type="submit" class="btn">Make Private</button>
            </form>
            {{else}}
            <form action="/date/{{date._id}}/publish" method="POST" class="form-inline">
                <button type="submit" class="btn">Publish</button>
            </form>
            {{/if}}
        </div>
        {{/if}}

        <div class="vote-row">
            <form id="upvote-form-{{date._id}}" action="/date/{{date._id}}/upvote" method="POST" class="form-inline">
                <button type="submit" class="vote-btn up">&#9650; {{date.votes.upvotes}}</button>
            </form>
            <form id="downvote-form-{{date._id}}" action="/date/{{date._id}}/downvote" method="POST" class="form-inline">
                <button type="submit" class="vote-btn down">&#9660; {{date.votes.downvotes}}</button>
            </form>
        </div>
    </div>

    <div class="event-steps">
        {{#each date.events}}
        <div class="event-step">
            <div class="event-card">
                <strong>{{this.spotName}}</strong>
                <a href="/spots/{{this.spotId}}" class="tag">View Spot </a>
                {{#if this.notes}}
                <p>{{this.notes}}</p>
                {{/if}}
                {{#if ../date.isCreator}}
                <form action="/date/{{../date._id}}/spot/{{this._id}}/delete" method="POST" class="form-inline">
                    <button type="submit" class="btn btn-red">Remove</button>
                </form>
                {{/if}}
            </div>
        </div>
        {{#unless @last}}<span class="step-arrow">&#8594;</span>{{/unless}}
        {{else}}
        <p>No events added yet.</p>
        {{/each}}
    </div>

    {{#if date.isCreator}}
    <div class="add-spot">
        <h3>Add a Spot</h3>
        <p class="date-meta">To add a spot to this date, visit a spot's page from <a href="/home">Home</a> and click "Add to Date".</p>
    </div>
    {{/if}}

    <div class="reviews-section">
<!--
        <form action="/date/{{date._id}}/comment" method="POST" class="form-box">
            <textarea name="comment" placeholder="Add a comment..." maxlength="250" required></textarea>
            <button type="submit" class="btn btn-blue">Post Comment</button>
        </form>
-->    
        <h2 class="section-title">Comments</h2>
        {{#each date.comments}}
        <div class="appeal-card">
            <div>
                <span>@{{this.username}}</span>
                <span class="date-meta">{{this.createdAt}}{{#if this.editedAt}} (edited {{this.editedAt}}){{/if}}</span>
            </div>
            <p>{{this.text}}</p>
            <div class="comment-actions">
                {{#if this.canEdit}}
                <button type="button" class="btn" onclick="toggleEditForm(this)">Edit</button>
                <form action="/date/{{../date._id}}/comment/{{this._id}}/edit" method="POST" class="form-inline edit-form" hidden>
                    <input type="text" name="comment" value="{{this.text}}" maxlength="250" required>
                    <button type="submit" class="btn">Save</button>
                </form>
                {{/if}}
                {{#if this.canDelete}}
                <form action="/date/{{../date._id}}/comment/{{this._id}}/delete" method="POST" class="form-inline">
                    <button type="submit" class="btn btn-red">Delete</button>
                </form>
                {{/if}}
            </div>
        </div>
        {{else}}
        <p>No comments yet.</p>
        {{/each}}

        {{#if date.isLoggedIn}}
        <form action="/date/{{date._id}}/comment" method="POST" class="comment-form">
            <textarea name="comment" placeholder="Add a comment..." maxlength="250" required></textarea>
            <button type="submit" class="btn">Post</button>
        </form>
        {{else}}
        <p><a href="/signin">Log in</a> to comment.</p>
        {{/if}}
    </div>
</div>

{{> votes}}
{{> commentEdit}}
