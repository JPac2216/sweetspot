{{> navbar}}

{{#if error}}
<div class="error-banner">{{error}}</div>
{{/if}}

<div class="page">
    <form id="date-create-form" action="/date/create" method="POST">
        <div class="form-group">
            <label>Title</label>
            <input type="text" id="title" name="title" class="title" value="{{date.title}}" placeholder="Date title" required>
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea id="description" name="description" class="description" placeholder="Describe your date..." required>{{date.description}}</textarea>
        </div>
        <div class="form-group">
            <label>Tags </label>
            <input type="text" id="tags" name="tags" class="tags" value="{{date.tagsRaw}}" placeholder="outdoor, free, food">
        </div>
        <div class="form-group">
            <label>Visibility</label>
            <select id="visibility" name="visibility" class="visibility">
                <option value="public">Public</option>
                <option value="private">Private</option>
            </select>
        </div>
        <div class="form-group">
            <label>Borough</label>
            <select id="borough" name="borough" class="borough" required>
                <option value="manhattan">Manhattan</option>
                <option value="brooklyn">Brooklyn</option>
                <option value="queens">Queens</option>
                <option value="the bronx">The Bronx</option>
                <option value="staten island">Staten Island</option>
            </select>
        </div>
        <div class="form-group">
            <label>Estimated Cost ($)</label>
            <input type="number" id="estimatedCost" name="estimatedCost" class="estimatedCost" min="0" step="0.01" value="{{date.estimatedCost}}" required>
        </div>

        <h2 class="section-title">Spots</h2>
        <p>Add spots from a location page. Use arrows to reorder.</p>

        <div class="event-steps" id="spotList">
            {{#each events}}
            <div class="event-step">
                <div class="event-card">
                    <input type="hidden" name="events[{{@index}}][spotId]" value="{{this.spotId}}">
                    <input type="hidden" name="events[{{@index}}][spotName]" value="{{this.spotName}}">
                    <input type="hidden" name="events[{{@index}}][order]" class="order-input" value="{{this.order}}">

                    <div>
                        <button type="button" class="btn-move-left vote-btn" onclick="moveCard(this,-1)" title="Move left">&#8678;</button>
                        <button type="button" class="btn-move-right vote-btn" onclick="moveCard(this,1)" title="Move right">&#8680;</button>
                    </div>

                    <strong>{{this.spotName}}</strong>
                    <p>{{this.borough}}</p>

                    <div class="tags">
                        {{#each this.tags}}
                        <span class="tag">{{this}}</span>
                        {{/each}}
                    </div>

                    <p>
                        {{#if this.sweetspotRating.average}}Rating: {{this.sweetspotRating.average}}{{/if}}{{#if this.estimatedCost}} / ${{this.estimatedCost}}{{/if}}
                    </p>
                </div>
            </div>
            {{#unless @last}}<span class="step-arrow">&#8594;</span>{{/unless}}            {{else}}
            <p>No spots added yet — visit a location page and use "Add to Date".</p>
            {{/each}}
        </div>

        <div class="form-group">
            <label>Notes</label>
            <textarea id="notes" name="notes" class="notes" placeholder="Special Notes...">{{date.notes}}</textarea>
        </div>

        <div class="form-actions">
            <button id="publish-btn" type="submit" name="action" value="publish" class="btn btn-filled">Save / Publish</button>
            <button id="save-draft-btn" type="submit" name="action" value="save" class="btn">Save Draft</button>
            <button id="delete-btn" type="button" class="btn btn-red">Delete</button>
        </div>
    </form>
</div>

{{> dateCreate}}
