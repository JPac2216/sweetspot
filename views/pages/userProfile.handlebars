<nav class="navbar">
    <a href="/home"><img src="/css/Sweet%20Spot.png" alt="Sweet Spot" class="logo"></a>
    <div class="nav-links">
        <a href="/spots/explore" class="nav-btn">Explore</a>
        <a href="/spots/appeal" class="nav-btn">Appeal</a>
        <a href="/date/create" class="nav-btn nav-btn-blue">Create +</a>
        <a href="/profile"><img src="/css/profile_icon.png" alt="My Profile" class="nav-icon"></a>
    </div>
</nav>

<div class="page">
    <div class="profile-header">
        <div class="profile-avatar">
            <img src="/css/profile_icon.png" alt="My Profile" class="nav-icon">
        </div>
        <div>
            <div class="profile-name">{{user.firstName}} {{user.lastName}}</div>
            <div class="date-meta">{{user.primaryLocation}}{{#if user.secondaryLocation}} / {{user.secondaryLocation}}{{/if}}</div>
        </div>
        <a href="/profile/edit" class="btn btn-blue">Edit Profile</a>
    </div>

    <div class="profile-section">
        <h2 class="section-title">Public Dates</h2>
        <div class="card-grid">
            {{#each publicDates}}
            <a href="/date/{{this._id}}" class="date-card">
                <div class="date-card-title">{{this.title}}</div>
                <div class="date-meta">{{this.borough}} / public</div>
            </a>
            {{else}}
            <p>No public dates yet.</p>
            {{/each}}
        </div>
    </div>

    <div class="profile-section">
        <h2 class="section-title">Private Dates</h2>
        <div class="card-grid">
            {{#each privateDates}}
            <a href="/date/{{this._id}}" class="date-card">
                <div class="date-card-title">{{this.title}}</div>
                <div class="date-meta">{{this.borough}} / private</div>
            </a>
            {{else}}
            <p>No private dates yet.</p>
            {{/each}}
        </div>
    </div>

    <div class="profile-section">
        <h2 class="section-title">Favorites</h2>
        <div class="card-grid">
            {{#each favoriteDates}}
            <a href="/date/{{this._id}}" class="date-card">
                <div class="date-card-title">{{this.title}}</div>
                <div class="date-meta">{{this.borough}}</div>
            </a>
            {{else}}
            <p>No favorites yet.</p>
            {{/each}}
        </div>
    </div>
</div>
